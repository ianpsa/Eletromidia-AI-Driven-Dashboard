HTTP_HOST=127.0.0.1
HTTP_PORT=5000

# Project Identifiers
FIREBASE_PROJECT_ID=your-firebase-project-id
GCP_PROJECT_ID=your-gcp-project-id

# Role Mappings (Format: ROLE_ALIAS=GCP_ROLE_NAME)
ROLE_ADMIN=roles/resourcemanager.projectIamAdmin
ROLE_EDITOR=roles/editor
ROLE_VIEWER=roles/viewer
ROLE_MANAGER=roles/owner

# GCP Authentication (Optional if using ADC locally)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
